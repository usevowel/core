PORT=3000
DB_PATH=./data/core.db

# Required for encrypting provider API keys (min 32 chars)
ENCRYPTION_KEY=

SNDBRD_URL=http://localhost:8787
SNDBRD_API_KEY=
SNDBRD_WS_URL=ws://localhost:8787

OPENAI_API_KEY=
XAI_API_KEY=

# Optional endpoint preset overrides (defaults are seeded automatically)
# ENDPOINT_PRESET_VOWEL_PRIME_STAGING_HTTP_URL=https://staging.prime.vowel.to
# ENDPOINT_PRESET_VOWEL_PRIME_STAGING_WS_URL=wss://staging.prime.vowel.to/v1/realtime

# Optional bootstrap app + publishable key seed (dev convenience)
# CORE_BOOTSTRAP_APP_ID=default
# CORE_BOOTSTRAP_APP_NAME=Default App
# CORE_BOOTSTRAP_APP_DESCRIPTION=Bootstrap app for local testing
# CORE_BOOTSTRAP_API_KEY_LABEL=Bootstrap key
# CORE_BOOTSTRAP_SCOPES=mint_ephemeral
# CORE_BOOTSTRAP_ALLOWED_PROVIDERS=vowel-prime
# CORE_BOOTSTRAP_ALLOWED_ENDPOINT_PRESETS=staging
# CORE_BOOTSTRAP_DEFAULT_ENDPOINT_PRESET=staging
# CORE_BOOTSTRAP_PUBLISHABLE_KEY=vkey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Tunnel (optional - for dev:tunnel)
# Get token from Cloudflare Zero Trust dashboard. Never commit.
# CLOUDFLARE_TUNNEL_TOKEN=
